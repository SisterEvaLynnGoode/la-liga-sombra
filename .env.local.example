# ─── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API

# Your project's public URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your project's anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Random 32+ char string — used to sign student session JWTs.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ─── Teacher access ───────────────────────────────────────────────────────────
# Simple password for /teacher/setup — share only with yourself.
TEACHER_PASSWORD=your-teacher-password-here

# ─── ElevenLabs audio generation ─────────────────────────────────────────────
# Used only by the local CLI (npm run audio:generate) — never sent to the browser.
# Get your API key at: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# Voice IDs from elevenlabs.io → Voices → [select a voice] → copy the Voice ID
# Recommended: use Multilingual v2 voices with a neutral Latin American accent.
# Suggested searches on ElevenLabs: "Valentina", "Sofia", "Diego", "Mateo"
ELEVENLABS_VOICE_FEMALE_1=  # Primary female narrator — neutral LatAm accent (e.g. Valentina)
ELEVENLABS_VOICE_MALE_1=    # Primary male narrator   — neutral LatAm accent (e.g. Diego)
ELEVENLABS_VOICE_FEMALE_2=  # Secondary female — used in units 5 & 7 (e.g. Sofia)
ELEVENLABS_VOICE_MALE_2=    # Secondary male   — used in units 6 & 8 (e.g. Mateo)
